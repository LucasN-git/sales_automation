# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Login allowlist (Magic-Link). Komma-separierte Listen, Domain-Whitelist + explizite Adressen.
# Mindestens eine der beiden Variablen muss gesetzt sein, sonst wird jeder Login abgelehnt.
ALLOWED_EMAIL_DOMAINS=isp-testing.de,isp-powersystems.com
ALLOWED_EMAILS=nasch.lucas@gmail.com

# Anthropic
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Browserbase (V4 robust listing for SPAs/Algolia)
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Resend (Mail-Versand)
# Magic-Link-Auth laeuft ueber Supabase Custom SMTP. Der API-Key wird direkt im
# Supabase-Dashboard hinterlegt (Authentication > SMTP Settings), NICHT hier.
# Diese Variablen sind fuer spaeteren direkten Resend-SDK-Einsatz reserviert
# (z.B. Outreach-Mails, Digest-Reports, Pipeline-Alerts).
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@send.isp-powersystems.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
